+  --panel-padding: var(--panel-padding-block);
+
+  @media (-moz-windows-mica-popups) {
+    appearance: auto;
+    -moz-default-appearance: menupopup;
+    /* The mica backdrop takes care of our shadow, border, and border-radius */
