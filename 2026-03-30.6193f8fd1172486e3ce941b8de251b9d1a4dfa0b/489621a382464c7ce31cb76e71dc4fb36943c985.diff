+GDIFontEntry::GDIFontEntry(const nsACString& aFaceName,
+                           gfxWindowsFontType aFontType, SlantStyleRange aStyle,
+                           WeightRange aWeight, StretchRange aStretch,
+                           gfxUserFontData* aUserFontData)
